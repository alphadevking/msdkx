{
  "name": "msdkx",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "check-types": "turbo check-types",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "audit": "pnpm audit --audit-level=moderate",
    "ci": "pnpm audit --audit-level=moderate && turbo lint check-types build",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm audit --audit-level=moderate && turbo check-types && turbo build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.10",
    "prettier": "^3.2.5",
    "turbo": "^2.3.3",
    "typescript": "5.5.4"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}
